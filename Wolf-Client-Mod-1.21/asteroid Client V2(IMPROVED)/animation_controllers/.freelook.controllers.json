{
"format_version": "1.10.0",
"animation_controllers": {





"controller.animation.head_x_rotation": {
"initial_state": "activate",
"states": {
"default": {
"on_entry": [
"!q.is_moving || q.is_moving"
],
"transitions": [
{ "activate": "!q.is_moving || q.is_moving"}
]
},
"activate": {
"on_entry": [
"v.head_x_rotation = (query.target_y_rotation);"
],
"transitions": [ { "default": "1.0" } ]
}
}
},

"controller.animation.head_y_rotation": {
"initial_state": "activate",
"states": {
"default": {
"on_entry": [
"!q.is_moving || q.is_moving"
],
"transitions": [
{ "activate": "!q.is_moving || q.is_moving" }
]
},
"activate": {
"on_entry": [
"v.head_y_rotation = (q.target_x_rotation);"
],
"transitions": [ { "default": "1.0" } ]
}
}
},
"controller.animation.body_x_rotation": {
"initial_state": "activate",
"states": {
"default": {
"on_entry": [
"!q.is_moving || q.is_moving"
],
"transitions": [
{ "activate": "!q.is_moving || q.is_moving" }
]
},
"activate": {
"on_entry": [
"v.body_x_rotation = q.body_y_rotation;"
],
"transitions": [ { "default": "1.0" } ]
}
}
}

}
} 