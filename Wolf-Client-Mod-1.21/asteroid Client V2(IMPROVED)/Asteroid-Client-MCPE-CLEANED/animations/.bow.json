{
  "format_version": "1.10.0",
  "animations": {

		"animation.elytra.gliding": {
			"loop": true,
			"bones": {
				"body": { "scale": 1.067 },
				"left_wing": {
					"position": [ 2, 2, -2 ],
					"rotation": [ "variable.ratio = (query.position_delta(1) < 0) ? 1 - math.pow(-query.movement_direction(1), 1.5) : 1; return math.lerp(15, 20, variable.ratio);", 0, "math.lerp(-15, -90, variable.ratio)" ],
					"scale": [ 1, 1, 2 ]
				},
				"right_wing": {
					"position": [ -2, 2, -2 ],
					"rotation": [ "variable.ratio = (query.position_delta(1) < 0) ? 1 - math.pow(-query.movement_direction(1), 1.5) : 1; return math.lerp(15, 20, variable.ratio);", 0, "math.lerp(15, 90, variable.ratio)" ],
					"scale": [ 1, 1, 2 ]
				}
			}
		},

    "animation.bow.wield": {
      "loop": true,
      "bones": {
        "rightitem": {
          "position": [ "c.is_first_person ? -4.0 : 0.0", "c.is_first_person ? -2.0 : 0.0", "c.is_first_person ? -1.0 : 0.0" ],
          "rotation": [ "c.is_first_person ? -15.0 : 0.0", "c.is_first_person ? 55.0 : 0.0", "c.is_first_person ? -35.0 : 0.0" ],
          "scale":"c.is_first_person ? 0.4 :1"
        }
      }
    },
    "animation.bow.wield_first_person_pull": {
      "loop": true,
      "bones": {
        "rightitem": {
          "position": [ "c.is_first_person ? -4.0 : 0.0", "c.is_first_person ? -2.0 : 0.0", "c.is_first_person ? -1.0 : 0.0" ],
          "rotation": [ "0.0",0, "0.0" ],
          "scale":"c.is_first_person ? 0.7 :1"
        }
      }
    }
  }
}