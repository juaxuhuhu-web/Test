"chat_grid_item": {
"type": "panel",
"layer": 1,
"controls": [
{
"chat_label": {
"type": "label",
"anchor_from": "top_left",
"anchor_to": "top_left",
"offset": [2, 2],
"size": [ "100%", "default" ],
"layer": 31,
"text": "#text",
"enable_profanity_filter":false,
"shadow": true,
"color": "$chat_text_color",
"font_type": "$chat_font_type",
"line_padding": 0.0,
"anims":["hud.anim_chat_txt_wait"],
"bindings": [
{
"binding_name": "#chat_text",
"binding_name_override": "#text",
"binding_type": "collection",
"binding_collection_name": "chat_text_grid",
"binding_condition": "once"
}
]
}
}
]
},

"chat_panel": {
"size": ["40%", "100%"],
"anchor_from": "bottom_left",
"anchor_to": "bottom_left",
"offset":[0,-45],
"bindings":[
{
"binding_type":"view",
"source_control_name":"asteroid.toggle.mod.chat",
"source_property_name":"(not #toggle_state)",
"target_property_name":"#visible"
}
],
"controls": [
{
"stack_panel": {
"type": "stack_panel",
"anchor_from": "bottom_left",
"anchor_to": "bottom_left",
"factory": {
"name": "chat_item_factory",
"max_children_size": 50,
"control_ids": {
"chat_item": "chat_item@hud.chat_grid_item"
}
}
}
}]
},

"anim_chat_txt_wait": {
"anim_type":"offset",
"easing":"out_cubic",
"duration":2,
"from":[0,10],
"next":"@hud.anim_chat_txt_wait1",
"to":[0,0]
},
"anim_chat_txt_wait1": {
"anim_type": "alpha",
"easing": "in_quart",
"duration": 2,
"from": 1,
"to": 0,
"destroy_at_end":"chat_grid_item"
},



"root_panel/sidebar": {
"bindings":[
{
"binding_type":"view",
"source_control_name":"asteroid.toggle.mod.scoreboard",
