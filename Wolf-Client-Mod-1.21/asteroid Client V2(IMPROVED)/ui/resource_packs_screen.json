"resource_packs_section_toggle_base@common_toggles.light_ui_toggle": {

"anchor_from": "top_left",

"anchor_to": "top_left",
"size": [ "100%", "30px" ],
"$button_size_override": [ "100%", "100% + 1px" ],

"$button_type_panel": "resource_packs.resource_packs_toggle_button_control",

