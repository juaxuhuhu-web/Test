}
}
]
},

"section_toggle_base@common_toggles.light_ui_toggle": {
"anchor_from": "top_left",
"anchor_to": "top_left",
"size": [ "100%", "25px"],
"$button_size_override": [ "100%", "100% + 1px" ],
"$button_type_panel": "settings_common.toggle_button_control",
"$default_texture":"textures/uidx/background_ui",
"$hover_texture": "textures/uidx/buttons/green2",
"$pressed_texture": "textures/uidx/buttons/green2",

"$unchecked_control": "common_toggles.toggle_unchecked",

"$checked_control": "common_toggles.toggle_unchecked",



"$pressed_no_hover_texture": "textures/uidx/buttons/green2",
"$radio_toggle_group": true,
"$toggle_name": "navigation_tab",
"$toggle_group_default_selected": 1,

"$toggle_tab_focus_binding_type": "global",
"$toggle_tab_focus_binding_name": "#navigation_tab_focus_precedence",
"$toggle_on_hover_binding_type": "global",
"$toggle_on_hover_binding_name": "#toggle_on_hover",
"$toggle_tts_toggle_on_text": "accessibility.state.selected",
"$toggle_tts_toggle_off_text": "accessibility.state.unselected",
"$toggle_tts_name": "accessibility.tab.tts.title"
},


"toggle_button_control": {
"type": "panel",
"layer": 2,
"controls": [
{
"tab_button_text": {
"type": "label",
"shadow":true,
"anchor_from": "center",
"anchor_to": "center",
"text": "$button_text",
"layer": 3
}
}
]
},





"settings_content@common_dialogs.main_panel_settings":{
"size":["97%","97%"],
"offset":[0,0],
"$child_control":"$dialog_content",
"$text_name":" ",
"$fill_alpha":0
},

  "store_top_bar_filler": {

    "type": "image",

    "texture": "textures/null"
  },
  
  
"dynamic_dialog_screen@common.base_screen":{
"type":"screen",
    "$header_safezone_control": "settings_common.store_top_bar_filler",
    "$header_bar_control": "settings_common.store_top_bar_filler",
"force_render_below": false,
"cache_screen":true,
"button_mappings":[
{
"from_button_id":"button.menu_cancel",
"to_button_id":"button.menu_exit",
"mapping_type":"global"
},
{
"from_button_id":"button.menu_tab_left",
"to_button_id":"button.menu_tab_left",
"mapping_type":"global",
"scope":"view"
},
{
"from_button_id":"button.menu_tab_right",
"to_button_id":"button.menu_tab_right",
"mapping_type":"global",
"scope":"view"
}
],
"$screen_content":"settings_common.settings_content",
"$screen_bg_content":"settings_common.settings_background",
"$is_full_screen_layout":true
},

"screen_base@settings_common.dynamic_dialog_screen": {
"$dialog_content": "settings_common.dialog_content"

},





"startbganim1": {
"anim_type":"offset",
"easing":"out_cubic",
"duration":1,
"from":[50,0],
"to":[0,0],
"next":"@startbganim2"
},

"startbganim2": {
"anim_type":"offset",
"easing":"out_cubic",
"duration":1,
"from":[-50,0],
"to":[0,0],
"next":"@startbganim1"
},

"settings_background": {
"type":"custom",
"renderer":"gradient_renderer",
"color1":[0,0.45,0.5,0.2],
"color2":[0,0.70,0.57,0.2]
}
}
