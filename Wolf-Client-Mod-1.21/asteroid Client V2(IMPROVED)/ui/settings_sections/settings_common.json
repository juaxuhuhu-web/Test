"option_toggle_on_locked@settings_common.option_toggle_state_template": {
"texture": "textures/uidx/background_ui",
"alpha": 0.5,
"controls": [
{
"option_label": {
"type": "label",
"$on_label|default": "ON",
"text_alignment": "center",
"color": [ 0.333, 0.5, 1 ],
"layer": 1,
"size": [ "100%", "default" ],
"anchor_from": "center",
"anchor_to": "center",
"text": "$on_label",
