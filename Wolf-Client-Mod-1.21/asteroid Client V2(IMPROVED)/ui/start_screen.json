{
"namespace": "start",




"clientname":{
"type":"label",
"offset":[0,20],
"layer":8,
"text":"Asteroid Client"
},
"gamerpic": {
"type": "image",
"layer": 3,
"size": [18,15],
"offset": [0,5],
"bindings": [
{
"binding_name": "#gamerpic_texture_path",
"binding_name_override": "#texture"
},
{
"binding_name": "#gamerpic_texture_location_type",
"binding_name_override": "#texture_file_system"
}
]
},



"start_screen@common.base_screen": {
"$screen_content": "start.start_screen_content"
},



"start_bg":{
"type":"image",
"texture":"textures/uidx/start_bg",
"anims":["@start.startbganim1"],
"size":["250%","250%"]
},

"start_screen_content":{
"type":"image",
"texture":"textures/null",
"controls":[
{
"start_bg@start_bg":{}
},

{
"start_screen_content_main": {
"type": "panel",
"size":["100%","100%"],
"controls": [
{
"version": {
"type": "label",
"color": "$main_header_text_color",
"layer": 8,
"text": "#version",
"$font_scale_factor":1.5,
"size": [ "default", 10 ],
"max_size": [ "100%", "100%" ],
"anchor_from": "bottom_right",
"anchor_to": "bottom_right",
"bindings": [
{
"binding_name": "#version"
}
]
}
},
{
"copyright": {
"type": "label",
"color": "$main_header_text_color",
"layer": 8,
"$font_scale_factor":1.5,
"text": "menu.copyright",
"size": [ "default", 10 ],
"max_size": [ "100%", "100%" ],
"anchor_from": "bottom_left",
"anchor_to": "bottom_left"
}
},
{
"top_left@start.top_left":{
}
},
{"top_right@start.top_right":{}},
{
"exit_button@common_buttons.light_text_button":{
"$pressed_button_name":"button.menu_exit",
"anchor_from":"top_right",
"anchor_to":"top_right",
"$button_text":"X",
"size":[20,20],
"offset":[-10,0],
"layer":15,
"$hover_button_texture": "textures/uidx/buttons/red2",
"$pressed_button_texture": "textures/uidx/buttons/red2",
"$default_button_texture":"textures/uidx/buttons/red2"
}
},
{
"center_panel@start.center_panel":{}
}
]
}
}
]
},


 "top_left":{
 "type":"image",
"size":[80,20],
"anchor_from":"top_left",
"anchor_to":"top_left",
"texture":"textures/null",
"controls":[
{

 
"top_left":{
"type":"panel",
"size":[80,20],
"anchor_from":"top_left",
"anchor_to":"top_left",
"controls":[
{
"logo":{
"type":"image",
"size":[20,20],
"layer":8,
"anchor_from":"left_middle",
"anchor_to":"left_middle",
"texture":"textures/uidx/glyphs/logo"
}
},
{
"clientname":{
"type":"label",
"offset":[20,0],
"layer":8,
"shadow":true,
"anchor_from":"left_middle",
"anchor_to":"left_middle",
"text":"client.name"
}
},
{
"store_button@common_buttons.light_text_button":{
"$pressed_button_name":"button.menu_store",
"anchor_from":"left_middle",
"anchor_to":"left_middle",
"$button_text":"Marketplace",
"size":[60,20],
"offset":[100,0],
"$font_type":"smooth",
"layer":15,
"$hover_button_texture": "textures/null",
"$pressed_button_texture": "textures/null",
"$default_button_texture":"textures/null"
}
},
{
"skins_button@common_buttons.light_text_button":{
"size":[60,20],
"$button_text":"Skins",
"layer":15,
"$font_type":"smooth",
"offset":[150,0],
"$hover_button_texture": "textures/null",

"$pressed_button_texture": "textures/null",
"$default_button_texture":"textures/null",
"$pressed_button_name":"button.menu_skins"
}
}

]
}}
 ]
 },
 
 
 
"startbganim1": {
"anim_type":"offset",
"easing":"in_out_quad",
"duration":12,
"from":[50,0],
"to":[-50,0],
"next":"@start.startbganim2"
},

"startbganim2": {
"anim_type":"offset",
"easing":"in_out_quad",
"duration":12,
"from":[-50,0],
"to":[50,0],

"next":"@start.startbganim1"
},

"center_panel":{
"type":"image",
"texture":"textures/null",
"size":[1000,1000],
"layer":0,
"alpha":0.5,
"controls":[
{
"panel":{
"type":"panel",
"size":[130,120],
"controls":[
{
"logo":{
"type":"image",
"size":[130,120],
"layer":8,
"texture":"textures/uidx/background_ui",
"controls":[
{
"logo":{
"type":"image",
"size":[80,80],
"offset":[0,-5],
"layer":8,
"anchor_from":"top_middle",
"anchor_to":"top_middle",
"texture":"textures/uidx/glyphs/logo"
}
},
{
"play_button@common_buttons.light_text_button": {
"$pressed_button_name": "$play_button_target",
"$button_text": "menu.play",
"$font_type":"smooth",
"anchor_from":"bottom_middle",
"size":["80%",15],
"offset":[0,-30],
"anchor_to":"bottom_middle",
"$hover_button_texture": "textures/uidx/buttons/green2",



"$pressed_button_texture": "textures/uidx/buttons/green2",

"$default_button_texture":"textures/uidx/pause_panel"
}
},
{

"settings_button@common_buttons.light_text_button": {
"$pressed_button_name": "button.menu_settings",
"$button_text": "menu.settings",
"$font_type":"smooth",
"anchor_from":"bottom_middle",
"size":["80%",15],
"offset":[0,-15],
"anchor_to":"bottom_middle",
"$hover_button_texture": "textures/uidx/buttons/green2",

"$pressed_button_texture": "textures/uidx/buttons/green2",

"$default_button_texture":"textures/uidx/pause_panel"
}
}
]
}
}
]
}
}
]
},
 

"top_right":{
"type":"image",
"size":[120,20],
"offset":[-30,0],
"anchor_from":"top_right",
"anchor_to":"top_right",
"texture":"textures/uidx/pause_panel",
"controls":[
{
"top_right":{
"type":"stack_panel",
"offset":[2,3],
"anchor_from":"left_middle",
"anchor_to":"left_middle",
"orientation":"horizontal",
"controls":[
{
"gamerpic@start.gamerpic":{
}
},
{
"gamertag":{
"type":"label",
"text":"#playername",
"layer":3,
"bindings":[
{
"binding_name":"#playername"
}
]
}
}

]
}
}
]
}

}

