

{
"namespace":"crafting_pocket",


"survival_inventory_grid": {
"$grid_rescaling_type": "vertical",
"$grid_item_template": "crafting_pocket.grid_item_for_inventory"
},





"both_panels": {
"type": "stack_panel",
"size": [ "100%", "100%" ],
"orientation": "horizontal",
"controls": [
{
"left_tab_navigation_panel_pocket@crafting_pocket.left_tab_navigation_panel_pocket": {
"layer": 2
}
},
{
"left_panel@crafting_pocket.left_panel": {
"size": [ "fill", "100%" ]
}
},
{
"offset_panel": {
"type": "panel",
"size": [ 4, "100%" ],
"controls": [
{
"center_bg": {
"type": "image",
"texture": "textures/null",
"size": [ 0,0]
}
}
],
"bindings": [
{
"binding_name": "#pocket_right_pane_visible",
"binding_name_override": "#visible"
}
]
}
},
{
"right_panel@crafting_pocket.right_panel": {
"size": [ "35%", "100%" ],
"bindings": [
{
"binding_name": "#pocket_right_pane_visible",
"binding_name_override": "#visible"
}
]
}
},
{
"right_tab_navigation_panel_pocket@crafting_pocket.right_tab_navigation_panel_pocket": {
"layer": 2
}
}
]
},

"right_panel": {
"type": "input_panel",
"size": [ "100%", "100%" ],
"layer": 5,
"controls": [
{
"right_background@common.common_panel": {
"$dialog_background": "common.dialog_background_opaque",
"$show_close_button": false
}
},
{
"crafting_tab_content@crafting_pocket.right_tab_content": {
"$right_tab_view_toggle_name": "crafting_tab_toggle",
"$right_tab_content_control": "$top_half_variant"
}
},
{
"armor_tab_content@crafting_pocket.right_tab_content": {
"$right_tab_view_toggle_name": "armor_tab_toggle",
"$right_tab_content_control": "crafting_pocket.pocket_armor_tab_content_1"
}
}
]
},

"pocket_armor_tab_content_1": {
"type": "panel",
"size": [ "100% - 12px", "100% - 12px" ],
"anchor_to": "center",
"anchor_from": "center",
"controls": [
{
"label_and_renderer": {
"type": "stack_panel",
"orientation":"verical",
"anchor_to": "top_middle",
"anchor_from": "top_middle",
"size": [ "100%", "fill" ],
"offset":["25%",0],
"controls": [
{
"armor_renderer": {
"type": "custom",
"size": [ 1, 1 ],
"layer": 2,
"renderer": "armor_renderer"
}
},
{
"heart_renderer": {
"type": "custom",
"size": [ 1, 1 ],
"renderer": "heart_renderer",
"layer": 1
}
}
]
}
},
{
"equipment": {
"type": "stack_panel",
"orientation": "horizontal",
"anchor_from": "bottom_middle",
"anchor_to": "bottom_middle",
"size": [ 140 ,28],
"controls": [
{
"armor_grid": {
"type": "grid",
"layer": 1,
"size": [ 112,28],
"grid_dimensions": [ 4,1],
"$item_collection_name": "armor_items",
"collection_name": "$item_collection_name",
"$item_renderer_panel_size": [ 28, 28 ],
"$item_renderer_size": [ 24, 24 ],
"$durability_bar_size": [ 18, 1 ],
"$durability_bar_offset": [ 0, 8 ],
"$armor_overlay_size": [ 24, 24 ],
"controls": [
{
"head_grid_item@common.container_item": {
"size": [ 28, 28 ],
"grid_position": [ 0, 0 ],
"$cell_image_size": [ 28, 28 ],
"$cell_overlay_ref": "crafting.armor_overlay_helmet",
"$button_ref": "crafting.no_coalesce_container_slot_button"
}
},
{
"chest_grid_item@common.container_item": {
"size": [ 28, 28 ],
"grid_position": [ 1,0],
"$cell_image_size": [ 28, 28 ],
"$cell_overlay_ref": "crafting.armor_overlay_chest",
"$button_ref": "crafting.no_coalesce_container_slot_button"
}
},
{
"legs_grid_item@common.container_item": {
"size": [ 28, 28 ],
"grid_position": [ 2,0],
"$cell_image_size": [ 28, 28 ],
"$cell_overlay_ref": "crafting.armor_overlay_legs",
"$button_ref": "crafting.no_coalesce_container_slot_button"
}
},
{
"feet_grid_item@common.container_item": {
"size": [ 28, 28 ],
"grid_position": [3,0],
"$cell_image_size": [ 28, 28 ],
"$cell_overlay_ref": "crafting.armor_image_feet",
"$button_ref": "crafting.no_coalesce_container_slot_button"
}
}
]
}
},
{
"offhand_grid": {
"type": "grid",
"layer": 1,
"size": [ 28, 28 ],
"grid_dimensions": [ 1, 1 ],
"$item_collection_name": "offhand_items",
"collection_name": "$item_collection_name",
"$item_renderer_panel_size": [ 28, 28 ],
"$item_renderer_size": [ 24, 24 ],
"$durability_bar_size": [ 18, 1 ],
"$durability_bar_offset": [ 0, 8 ],
"$offhand_overlay_size": [ 24, 24 ],
"controls": [
{
"offhand_grid_item@common.container_item": {
"size": [ 28, 28 ],
"grid_position": [ 0, 0 ],
"$cell_image_size": [ 28, 28 ],
"$cell_overlay_ref": "crafting.armor_overlay_shield",
"$button_ref": "crafting.no_coalesce_container_slot_button"
}
}
]
}
}
]
}
},
{
"player_renderer": {
"type": "custom",
"renderer": "live_player_renderer",
"layer": 20,
"size": [ 50,50],
"offset": [ 0, -90 ],
"anchor_from": "bottom_middle",
"anchor_to": "bottom_middle"
}
}
]
},





"crafting_arrow_down":{
"controls":[
{
"quick_craft_button@crafting.quick_craft_button":{
"size":[32,32],
"offset":[0,0]
}
}
]
}}