{
"format_version" : "1.8.0",
"render_controllers" : {

"controller.render.asteroid.empty_helmet" : {
"geometry" : "Geometry.asteroid.casco.interfaz",
"part_visibility":[{"*":"q.is_in_ui"}],
"materials" : [{"*": "Material.default"}],
"arrays": {
"textures": {
"array.helmet":[
"texture.leather_helmet",
"texture.chainmail_helmet",
"texture.iron_helmet",
"texture.diamond_helmet",
"texture.gold_helmet",
"texture.gold_helmet",
"texture.turtle_helmet",
"texture.netherite_helmet"
]
}
},
"textures" : ["array.helmet[q.armor_texture_slot(0)]"],
"overlay_color": {
"r":"v.casco_encantado ? 0.4 : 0.0",
"g":0.0,
"b":"v.casco_encantado",
"a":"v.casco_encantado ? 0.05 * math.cos(query.life_time* 425.0) + 0.25 : 0.0"
},
"light_color_multiplier": "v.casco_encantado ? 0.05 * -math.cos(query.life_time * 500.0) + 1.5: 1",
"ignore_lighting":true
},






