"asteroid_durability_percent": {
"$valor_total": "#item_durability_total_amount" ,
"$valor_actual": "#item_durability_current_amount" ,
"bindings": [
{
"binding_name": "$valor_total" ,
"binding_type": "collection" ,
"binding_collection_name": "hotbar_items"
},
{
"binding_name": "$valor_actual" ,
"binding_type": "collection" ,
"binding_collection_name": "hotbar_items"
},
{
"binding_type": "view" ,
"source_property_name": "((($valor_actual / $valor_total) > $durabilidad_minima) and (($valor_actual / $valor_total) < $durabilidad_maxima)) or (($valor_actual / $valor_total) = $durabilidad_minima)" ,
"target_property_name": "#visible"
}
]
},

"durability": {
"type": "grid" ,
"grid_item_template": "asteroid_hud_content.view_panel" ,
