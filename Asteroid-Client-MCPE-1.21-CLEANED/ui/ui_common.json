{
"namespace":"common",




"slider_border": {
"type": "image",
"texture": "textures/null"
},


  "inventory_hold_icon": {
    "type": "custom",
    "renderer": "progress_bar_renderer",
    "layer": 70,
    "offset": [0,-16],
    "size": [ 15, 2 ],
    "bindings": [
      {
        "binding_name": "#progress_bar_visible",
        "binding_condition": "always"
      },
      {
        "binding_name": "#progress_bar_total_amount",
        "binding_condition": "always_when_visible"
      },
      {
        "binding_name": "#progress_bar_current_amount",
        "binding_condition": "always_when_visible"
      }
    ]
  },

"dropdown_background": {
"layer": 1,
"type": "image",
"alpha":2,
"texture": "textures/uidx/background_ui"
},

"dialog_background_hollow_common@dialog_background_common": {
"layer": 2,
"$fill_alpha|default": 0.0,
"$dialog_background_texture|default": "textures/ui/control",
"variables": [
{
"requires": "$is_holographic",
"$fill_alpha": 0.0
}
],
"controls": [
{
"control": {
"type": "image",
"texture": "$dialog_background_texture",
"layer": -1,
"size": [ "100% - 8px", "100% - 8px" ],
"alpha": "$fill_alpha"
}
}
]
},






"highlight_slot_panel/highlight":{
"modifications":[{
"array_name":"bindings",
"operation":"remove",
"where":{
"binding_name":"(not #using_touch)"
}
}]
},

"highlight_slot_panel/white_border":{
"modifications":[{
"array_name":"bindings",
"operation":"remove",
"where":{
"binding_name":"(not #using_touch)"
}
}]
},

"inventory_icon_panel/hover_text":{
"ignored":false
},

"flying_item_renderer":{
"visible":false
},


"screen_background": {
"type": "image",
"texture": "textures/null",
"layer": -10,
"ignored": "$is_holographic",
"$screen_background_alpha|default": 0.75,
"alpha": 0
},

"selected_item_details/item_panel_image":{
"visible":false
},

"scroll_box/box/mouse_box":{
"ignored":true
},

"scroll_box/box":{
"modifications":[{
"control_name":"touch_box",
"operation":"remove"
}]
},

"scrolling_panel/scroll_mouse":{
"ignored":false
},

"scrolling_panel":{
"modifications":[
{
"control_name":"scroll_touch",
"operation":"remove"
}]
},


"selected_item_details":{
"type":"panel",
"anchor_to":"bottom_middle",
"anchor_from":"bottom_middle",
"size":["100%c","100%c"],
"layer":30,
"$alpha_anim|default":"@common.anim_item_details_alpha",
"controls":[{
"item_panel_image":{
"type":"image",
"size":["100%c+8px","100%c+8px"],
"layer":30,
"alpha":"$alpha_anim",
"texture":"textures/ui/hud_tip_text_background",
"controls":[
{
"item_text_label":{
"type":"label",
"layer":1,
"alpha":"$alpha_anim",
"font_scale_factor":0.7,
"text":"#selected_hover_text",
"color":"$item_hover_text_color"
}
}]
}
}]
},

"cell_image": {
"type": "image",
"texture":"$cell_bg",
"$cell_bg|default": "textures/ui/cell_image",
"layer": 1
},



"selected_item_details_factory":{
"type":"factory",
"control_name":"@common.selected_item_details"
},





"durability_bar":{
"type":"custom",
"renderer":"progress_bar_renderer",
"layer":10,
"$durability_bar_size|default":[12,1],
"$durability_bar_offset|default":[0,5],
"offset":"$durability_bar_offset",
"size":"$durability_bar_size",
"property_bag":{
"is_durability":true,
"round_value":false
},
"bindings":[{
"binding_name":"#item_durability_visible",
"binding_name_override":"#progress_bar_visible",
"binding_type":"collection",
"binding_collection_name":"$item_collection_name"
},
{
"binding_name":"#item_durability_total_amount",
"binding_name_override":"#progress_bar_total_amount",
"binding_type":"collection",
"binding_collection_name":"$item_collection_name"
},
{
"binding_name":"#item_durability_current_amount",
"binding_name_override":"#progress_bar_current_amount",
"binding_type":"collection",
"binding_collection_name":"$item_collection_name"
}]
}
}








