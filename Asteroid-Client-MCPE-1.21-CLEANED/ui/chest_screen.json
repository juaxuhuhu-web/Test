

{
"namespace":"chest",




"small_chest_panel":{
"type":"panel",
"size":["100%","100%"],
"controls":[
{
"small_chest_panel":{
"type":"image",
"size":[180,170],
"texture":"textures/uidx/black",
"controls":[
                    { "inventory_take_progress_icon_button@common.inventory_take_progress_icon_button": {} },
{
"panel":{
"type":"panel",
"anchor_from":"top_right",
"anchor_to":"top_right",
"offset":[8.5,7],
"controls":[
{
"stack_panel":{
"type":"stack_panel",
"anchor_to":"center",
"anchor_from":"center",
"size":["100%","100%"],
"orientation":"vertical",
"controls":[
{
"chest_label":{
"type":"label",
"text":"$container_title",
"size":["90%","default"],
"color":"$title_text_color",
"layer":2
}
},
{
"small_chest_grid":{
"type":"grid",
"size":[162,54],
"anchor_from":"top_left",
"anchor_to":"top_left",
"grid_dimensions":[9,3],
"$cell_bg":"textures/uidx/pause_panel",
"grid_item_template":"chest.chest_grid_item",
"collection_name":"container_items"
}
},
{
"inventory_label":{
"type":"label",
"text":"container.inventory",
"size":["90%","default"],
"color":"$title_text_color",
"layer":2
}
},
{
"inventory_grid":{
"type":"grid",
"size":[162,54],
"grid_dimensions":[9,3],
"$cell_bg":"textures/uidx/pause_panel",
"grid_item_template":"common.grid_item_for_inventory",
"collection_name":"inventory_items"
}
},
{

"hotbar_label":{

"type":"label",
"text":"Hotbar",
"size":["90%","default"],
"color":"$title_text_color",
"layer":2
}
},
{"hotbar_grid@common.hotbar_grid_template":{
"$cell_bg":"textures/uidx/pause_panel"
}}
]
}
}
]
}
},
{

"exit_button@common_buttons.light_text_button":{
"$pressed_button_name":"button.menu_exit",
"anchor_from":"top_right",
"anchor_to":"top_right",
"$button_text":"X",
"size":[20,20],
"offset":[20,0],
"layer":15,
"$hover_button_texture":"textures/uidx/buttons/red2",
"$pressed_button_texture":"textures/uidx/buttons/red2",
"$default_button_texture":"textures/uidx/buttons/red2"
}
}

]
}
}
]
},

"selected_item_details@common.selected_item_details":{
"offset":[0,0]
},



