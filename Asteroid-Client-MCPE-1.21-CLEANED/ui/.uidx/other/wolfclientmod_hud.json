{
  "namespace": "wolfclientmod_hud",
  "wolfclientmod_hud": {
    "type": "panel",
    "size": ["100%", "100%"],
    "controls": [
      {
        "show_mod_panel@pausett.wolfclientmod_toggle_custom_center": {
          "$toggle_view_binding_name": "wolfclientmod.show.mod.menu",
          "size": [60, 20],
          "$on_texture": "textures/ui/button_hover",
          "$off_texture": "textures/ui/button_default",
          "$hover_texture": "textures/ui/button_hover",
          "anchor_from": "bottom_right",
          "anchor_to": "bottom_right",
          "offset": [0, 0],
          "layer": 3,
          "$show_text": "MODS",
          "$hide_text": "CLOSE"
        }
      },
      {
        "mod_menu_panel": {
          "type": "panel",
          "size": ["70%", "80%"],
          "anchor_from": "center",
          "anchor_to": "center",
          "layer": 5,
          "controls": [
            {
              "background": {
                "type": "image",
                "texture": "textures/ui/panel",
                "size": ["100%", "100%"],
                "layer": 1
              }
            },
            {
              "title": {
                "type": "label",
                "text": "Wolf Client Mod Menu",
                "anchor_from": "top_center",
                "anchor_to": "top_center",
                "offset": [0, 10],
                "layer": 6
              }
            },
            {
              "modules_button@pausett.wolfclientmod_section_toggle": {
                "$toggle_view_binding_name": "wolfclientmod.show.modules",
                "$button_text": "Modules",
                "size": ["30%", "8%"],
                "anchor_from": "top_left",
                "anchor_to": "top_left",
                "offset": [10, 40],
                "$on_texture": "textures/ui/button_hover",
                "$off_texture": "textures/ui/button_default"
              }
            },
            {
              "crosshair_button@pausett.wolfclientmod_section_toggle": {
                "$toggle_view_binding_name": "wolfclientmod.show.crosshair",
                "$button_text": "Crosshair",
                "size": ["30%", "8%"],
                "anchor_from": "top_left",
                "anchor_to": "top_left",
                "offset": [10, 60],
                "$on_texture": "textures/ui/button_hover",
                "$off_texture": "textures/ui/button_default"
              }
            },
            {
              "music_button@pausett.wolfclientmod_section_toggle": {
                "$toggle_view_binding_name": "wolfclientmod.show.music",
                "$button_text": "Music",
                "size": ["30%", "8%"],
                "anchor_from": "top_left",
                "anchor_to": "top_left",
                "offset": [10, 80],
                "$on_texture": "textures/ui/button_hover",
                "$off_texture": "textures/ui/button_default"
              }
            },
            {
              "drawable_button@pausett.wolfclientmod_section_toggle": {
                "$toggle_view_binding_name": "wolfclientmod.show.drawable",
                "$button_text": "Drawable",
                "size": ["30%", "8%"],
                "anchor_from": "top_left",
                "anchor_to": "top_left",
                "offset": [10, 100],
                "$on_texture": "textures/ui/button_hover",
                "$off_texture": "textures/ui/button_default"
              }
            },
            {
              "modules_panel@m_section.modules_panel": {
                "visible": false,
                "bindings": [
                  {
                    "binding_type": "view",
                    "source_control_name": "wolfclientmod.show.modules",
                    "source_property_name": "#toggle_state",
                    "target_property_name": "#visible"
                  }
                ]
              }
            },
            {
              "crosshair_panel@c_section.crosshair_section": {
                "visible": false,
                "bindings": [
                  {
                    "binding_type": "view",
                    "source_control_name": "wolfclientmod.show.crosshair",
                    "source_property_name": "#toggle_state",
                    "target_property_name": "#visible"
                  }
                ]
              }
            },
            {
              "music_panel@music_section.music_panel": {
                "visible": false,
                "bindings": [
                  {
                    "binding_type": "view",
                    "source_control_name": "wolfclientmod.show.music",
                    "source_property_name": "#toggle_state",
                    "target_property_name": "#visible"
                  }
                ]
              }
            },
            {
              "drawable_panel@d_section.drawable_section": {
                "visible": false,
                "bindings": [
                  {
                    "binding_type": "view",
                    "source_control_name": "wolfclientmod.show.drawable",
                    "source_property_name": "#toggle_state",
                    "target_property_name": "#visible"
                  }
                ]
              }
            }
          ],
          "bindings": [
            {
              "binding_type": "view",
              "source_control_name": "wolfclientmod.show.mod.menu",
              "source_property_name": "#toggle_state",
              "target_property_name": "#visible"
            }
          ]
        }
      }
    ]
  }
}