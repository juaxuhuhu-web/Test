{
  "namespace": "pausett",
  "wolfclientmod_section_toggle@common_toggles.light_ui_toggle": {
    "size": ["100%", "30px"],
    "$button_size_override": ["100%", "100% + 1px"],
    "$button_type_panel": "pausett.wolfclientmod_toggle_control_section",
    "$default_texture": "textures/ui/button_default",
    "$hover_texture": "textures/ui/button_hover",
    "$pressed_texture": "textures/ui/button_pressed",
    "$pressed_no_hover_texture": "textures/ui/button_pressed",
    "$locked_texture": "textures/ui/button_locked",
    "$radio_toggle_group": true,
    "$toggle_name": "mod_section",
    "$toggle_group_default_selected": 1,
    "$toggle_tab_focus_binding_type": "global",
    "$toggle_tab_focus_binding_name": "#mod_tab_focus_precedence",
    "$toggle_on_hover_binding_type": "global",
    "$toggle_on_hover_binding_name": "#toggle_on_hover"
  },
  "wolfclientmod_toggle_control_section": {
    "type": "panel",
    "layer": 2,
    "controls": [
      {
        "tab_button_text": {
          "type": "label",
          "shadow": true,
          "text": "$button_text",
          "layer": 3
        }
      }
    ]
  },
  "wolfclientmod_toggle_custom_center": {
    "type": "panel",
    "$toggle_view_binding_name": "this_toggle",
    "$template_toggle|default": "pausett.wolfclientmod_button_press_center",
    "controls": [
      {
        "$toggle_view_binding_name@$template_toggle": {}
      }
    ]
  },
  "wolfclientmod_button_press_center@common.toggle": {
    "$unchecked_control|default": "pausett.toggle_on_wolfclientmod_center",
    "$checked_control|default": "pausett.toggle_off_wolfclientmod_center",
    "$unchecked_hover_control|default": "pausett.toggle_on_to_off_wolfclientmod_center",
    "$checked_hover_control|default": "pausett.toggle_off_to_on_wolfclientmod_center"
  },
  "toggle_on_wolfclientmod_center": {
    "type": "image",
    "texture": "$on_texture",
    "controls": [
      {
        "toggle_label": {
          "type": "label",
          "layer": 101,
          "shadow": true,
          "text": "$show_text"
        }
      }
    ]
  },
  "toggle_off_wolfclientmod_center": {
    "type": "image",
    "texture": "$off_texture",
    "controls": [
      {
        "toggle_label": {
          "type": "label",
          "layer": 101,
          "shadow": true,
          "text": "$hide_text"
        }
      }
    ]
  },
  "toggle_on_to_off_wolfclientmod_center": {
    "type": "image",
    "texture": "$on_texture",
    "controls": [
      {
        "toggle_label": {
          "type": "label",
          "layer": 101,
          "shadow": true,
          "text": "$show_text"
        }
      }
    ]
  },
  "toggle_off_to_on_wolfclientmod_center": {
    "type": "image",
    "texture": "$off_texture",
    "controls": [
      {
        "toggle_label": {
          "type": "label",
          "layer": 101,
          "shadow": true,
          "text": "$hide_text"
        }
      }
    ]
  }
}



