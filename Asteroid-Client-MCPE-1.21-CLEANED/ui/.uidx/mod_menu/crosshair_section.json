{
  "namespace": "c_section",
  "crosshair_section": {
    "type": "stack_panel",
    "size": ["100%", "100%"],
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "controls": [
      {
        "crosshair_toggle@pausett.wolfclientmod_toggle_custom_center": {
          "$toggle_view_binding_name": "wolfclientmod.toggle.crosshair.enabled",
          "$on_texture": "textures/ui/button_hover",
          "$off_texture": "textures/ui/button_default",
          "size": ["90%", "40px"],
          "$show_text": "Crosshair: ON",
          "$hide_text": "Crosshair: OFF"
        }
      },
      {
        "crosshair_size_small@pausett.wolfclientmod_section_toggle": {
          "$toggle_view_binding_name": "wolfclientmod.crosshair.size.small",
          "$button_text": "Small",
          "size": ["90%", "40px"],
          "$on_texture": "textures/ui/button_hover",
          "$off_texture": "textures/ui/button_default"
        }
      },
      {
        "crosshair_size_medium@pausett.wolfclientmod_section_toggle": {
          "$toggle_view_binding_name": "wolfclientmod.crosshair.size.medium",
          "$button_text": "Medium",
          "size": ["90%", "40px"],
          "$on_texture": "textures/ui/button_hover",
          "$off_texture": "textures/ui/button_default"
        }
      },
      {
        "crosshair_size_large@pausett.wolfclientmod_section_toggle": {
          "$toggle_view_binding_name": "wolfclientmod.crosshair.size.large",
          "$button_text": "Large",
          "size": ["90%", "40px"],
          "$on_texture": "textures/ui/button_hover",
          "$off_texture": "textures/ui/button_default"
        }
      }
    ]
  }
}