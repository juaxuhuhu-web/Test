          "$show_text": "Drawable 1: ON",
          "$hide_text": "Drawable 1: OFF"
        }
      },
      {
        "drawable_2_toggle@pausett.wolfclientmod_toggle_custom_center": {
          "$toggle_view_binding_name": "wolfclientmod.toggle.drawable.2",
          "$on_texture": "textures/ui/button_hover",
