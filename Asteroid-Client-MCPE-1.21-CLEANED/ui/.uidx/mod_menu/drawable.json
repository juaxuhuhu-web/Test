{
  "namespace": "d_section",
  "drawable_section": {
    "type": "stack_panel",
    "size": ["100%", "100%"],
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "controls": [
      {
        "drawable_0_toggle@pausett.wolfclientmod_toggle_custom_center": {
          "$toggle_view_binding_name": "wolfclientmod.toggle.drawable.0",
          "$on_texture": "textures/ui/button_hover",
          "$off_texture": "textures/ui/button_default",
          "size": ["90%", "40px"],
          "$show_text": "Drawable 0: ON",
          "$hide_text": "Drawable 0: OFF"
        }
      },
      {
        "drawable_1_toggle@pausett.wolfclientmod_toggle_custom_center": {
