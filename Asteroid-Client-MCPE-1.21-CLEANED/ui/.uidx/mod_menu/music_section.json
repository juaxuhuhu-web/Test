{
  "namespace": "music_section",
  "music_panel": {
    "type": "stack_panel",
    "size": ["100%", "100%"],
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "controls": [
      {
        "music_toggle@pausett.wolfclientmod_toggle_custom_center": {
          "$toggle_view_binding_name": "wolfclientmod.toggle.music.enabled",
          "$on_texture": "textures/ui/button_hover",
          "$off_texture": "textures/ui/button_default",
          "size": ["90%", "40px"],
          "$show_text": "Music: ON",
          "$hide_text": "Music: OFF"
        }
      },
      {
        "music_volume_low@pausett.wolfclientmod_section_toggle": {
          "$toggle_view_binding_name": "wolfclientmod.music.volume.low",
          "$button_text": "Low Volume",
          "size": ["90%", "40px"],
          "$on_texture": "textures/ui/button_hover",
          "$off_texture": "textures/ui/button_default"
        }
      },
      {
        "music_volume_medium@pausett.wolfclientmod_section_toggle": {
          "$toggle_view_binding_name": "wolfclientmod.music.volume.medium",
          "$button_text": "Medium Volume",
          "size": ["90%", "40px"],
          "$on_texture": "textures/ui/button_hover",
          "$off_texture": "textures/ui/button_default"
        }
      },
      {
        "music_volume_high@pausett.wolfclientmod_section_toggle": {
          "$toggle_view_binding_name": "wolfclientmod.music.volume.high",
          "$button_text": "High Volume",
          "size": ["90%", "40px"],
          "$on_texture": "textures/ui/button_hover",
          "$off_texture": "textures/ui/button_default"
        }
      }
    ]
  }
}