{
  "namespace": "m_section",
  "modules_panel": {
    "type": "stack_panel",
    "size": ["100%", "100%"],
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "controls": [
      {
        "direction_toggle@pausett.wolfclientmod_toggle_custom_center": {
          "$toggle_view_binding_name": "wolfclientmod.toggle.mod.direction",
          "$on_texture": "textures/ui/button_hover",
          "$off_texture": "textures/ui/button_default",
          "size": ["90%", "40px"],
          "$show_text": "Direction Hud: ON",
          "$hide_text": "Direction Hud: OFF"
        }
      },
      {
        "armor_toggle@pausett.wolfclientmod_toggle_custom_center": {
          "$toggle_view_binding_name": "wolfclientmod.toggle.mod.armor",
          "$on_texture": "textures/ui/button_hover",
          "$off_texture": "textures/ui/button_default",
          "size": ["90%", "40px"],
          "$show_text": "Armor Hud: ON",
          "$hide_text": "Armor Hud: OFF"
        }
      },
      {
        "offhand_toggle@pausett.wolfclientmod_toggle_custom_center": {
          "$toggle_view_binding_name": "wolfclientmod.toggle.mod.offhand",
          "$on_texture": "textures/ui/button_hover",
          "$off_texture": "textures/ui/button_default",
          "size": ["90%", "40px"],
          "$show_text": "Offhand Hud: ON",
          "$hide_text": "Offhand Hud: OFF"
        }
      },
      {
        "mainhand_toggle@pausett.wolfclientmod_toggle_custom_center": {
          "$toggle_view_binding_name": "wolfclientmod.toggle.mod.mainhand",
          "$on_texture": "textures/ui/button_hover",
          "$off_texture": "textures/ui/button_default",
          "size": ["90%", "40px"],
          "$show_text": "Mainhand Hud: ON",
          "$hide_text": "Mainhand Hud: OFF"
        }
      },
      {
        "potion_toggle@pausett.wolfclientmod_toggle_custom_center": {
          "$toggle_view_binding_name": "wolfclientmod.toggle.mod.potion",
          "$on_texture": "textures/ui/button_hover",
          "$off_texture": "textures/ui/button_default",
          "size": ["90%", "40px"],
          "$show_text": "Potion Hud: ON",
          "$hide_text": "Potion Hud: OFF"
        }
      },
      {
        "chat_toggle@pausett.wolfclientmod_toggle_custom_center": {
          "$toggle_view_binding_name": "wolfclientmod.toggle.mod.chat",
          "$on_texture": "textures/ui/button_hover",
          "$off_texture": "textures/ui/button_default",
          "size": ["90%", "40px"],
          "$show_text": "Chat Hud: ON",
          "$hide_text": "Chat Hud: OFF"
        }
      }
